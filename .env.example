# Nomor owner (format internasional tanpa + atau @s.whatsapp.net, contoh: 6281234567890)
OWNER_NUMBER=6281234567890

# Nama bot
BOT_NAME=WangsafBot

# Prefix command (default: .)
PREFIX=.

# Nama session (dipakai untuk folder auth_info)
SESSION_NAME=my-wangsaf-bot

# ── Downloader ────────────────────────────────────────────────────────────────
# Path ke binary yt-dlp. Default: 'yt-dlp' (diasumsikan ada di PATH)
# Windows  : YTDLP_PATH=C:\tools\yt-dlp.exe
# Linux/Mac: YTDLP_PATH=yt-dlp
YTDLP_PATH=yt-dlp

# Path ke binary ffmpeg. Default: 'ffmpeg' (diasumsikan ada di PATH)
# Diperlukan untuk: ytmp4 transcode, sticker dari video
# Windows  : FFMPEG_PATH=C:\Users\Administrator\AppData\Local\Microsoft\WinGet\Links\ffmpeg.exe
# Linux/Mac: FFMPEG_PATH=ffmpeg
FFMPEG_PATH=ffmpeg

# Path ke binary ffprobe. Default: 'ffprobe' (diasumsikan ada di PATH)
# FFPROBE_PATH=ffprobe

# Timeout (ms) untuk request ke API TikTok (tikwm.com). Default: 20000
TIKTOK_TIMEOUT=20000

# Timeout (ms) untuk proses download yt-dlp. Default: 120000 (2 menit)
DOWNLOAD_TIMEOUT=120000

# ── Konfigurasi ytmp4 ─────────────────────────────────────────────────────────
# Aktifkan transcode ffmpeg setelah download (untuk kompatibilitas WhatsApp).
# Default: aktif (1). Set ke 0 untuk nonaktifkan (kirim file apa adanya dari yt-dlp).
YTMP4_TRANSCODE=1

# Tinggi maksimal video output setelah transcode (px). Default: 720
# Kurangi untuk menghemat ukuran file, misalnya 480
YTMP4_MAX_HEIGHT=720

# CRF (Constant Rate Factor) untuk encoding H.264. Default: 28
# Lebih kecil = kualitas lebih baik + ukuran lebih besar. Range: 18–35
YTMP4_CRF=28

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set ke 1 untuk mengaktifkan log debug proses download dan transcode
# DEBUG_DOWNLOAD=0
