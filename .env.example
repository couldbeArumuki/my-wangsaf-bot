# Nomor owner (format internasional tanpa + atau @s.whatsapp.net, contoh: 6281234567890)
OWNER_NUMBER=6281234567890

# Nama bot
BOT_NAME=WangsafBot

# Prefix command (default: .)
PREFIX=.

# Nama session (dipakai untuk folder auth_info)
SESSION_NAME=my-wangsaf-bot

# ── Downloader ────────────────────────────────────────────────────────────────
# Path ke binary yt-dlp. Default: 'yt-dlp' (diasumsikan ada di PATH)
# Windows  : YTDLP_PATH=C:\tools\yt-dlp.exe
# Linux/Mac: YTDLP_PATH=yt-dlp
YTDLP_PATH=yt-dlp

# Timeout (ms) untuk request ke API TikTok (tikwm.com). Default: 20000
TIKTOK_TIMEOUT=20000

# Timeout (ms) untuk proses download yt-dlp. Default: 120000 (2 menit)
DOWNLOAD_TIMEOUT=120000
