# Nomor owner (format internasional tanpa + atau @s.whatsapp.net, contoh: 6281234567890)
OWNER_NUMBER=6281234567890

# Nama bot
BOT_NAME=WangsafBot

# Prefix command (default: .)
PREFIX=.

# Nama session (dipakai untuk folder auth_info)
SESSION_NAME=my-wangsaf-bot

# ─── Downloader: yt-dlp microservice ─────────────────────────────────────────
# URL self-hosted yt-dlp service (lihat services/ytdlp-server.js)
# Wajib diisi agar .ytmp3 dan .ytmp4 berfungsi.
# Jalankan service-nya dengan: npm run ytdlp-service
# Untuk lokal: YTDLP_API_URL=http://localhost:3001
# Untuk VPS:   YTDLP_API_URL=http://<ip-vps>:3001
YTDLP_API_URL=http://localhost:3001

# Port yt-dlp service (default: 3001, harus sama dengan port di YTDLP_API_URL)
YTDLP_PORT=3001

# Timeout download yt-dlp dalam ms (default: 120000 = 2 menit)
YTDLP_TIMEOUT=120000

# ─── Downloader: TikTok (opsional) ───────────────────────────────────────────
# URL self-hosted TikTok API (opsional).
# Jika dikosongkan, bot menggunakan tikwm.com (API publik gratis).
# Format respons yang didukung: { url: "..." } atau { data: { play: "..." } }
TIKTOK_API_URL=
